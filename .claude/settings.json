{
  "$comment": "Hooks tiers audités (dépôt alirezarezvani/claude-skills). Désactivation : HANDOFF_SESSIONSTART=0 / HANDOFF_SESSIONEND=0 / ENABLE_SECURITY_REMINDER=0",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/plugins/handoff/hooks/session_start.py\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/plugins/handoff/hooks/session_end.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/plugins/security-guidance/hooks/security_reminder_hook.py\""
          }
        ]
      }
    ]
  }
}
