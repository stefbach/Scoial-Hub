# ─────────────────────────────────────────────────────────────
# Social Hub — variables d'environnement
# Copie ce fichier en `.env.local` et renseigne les valeurs.
# L'app tourne en MODE MOCK tant que ces clés sont absentes.
# ─────────────────────────────────────────────────────────────

# ── Supabase (backend / base de données / auth) ──────────────
# Dashboard Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé service_role — SERVEUR UNIQUEMENT, ne jamais exposer au client
SUPABASE_SERVICE_ROLE_KEY=

# ── IA — Génération de texte (Claude) ────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=
# Modèle par défaut pour la génération de posts
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── IA — Génération d'images ─────────────────────────────────
# Au choix (voir docs/AI-STACK.md). Ex : Replicate (Flux), OpenAI, fal.ai
REPLICATE_API_TOKEN=
OPENAI_API_KEY=
FAL_KEY=

# ── IA — Génération de vidéos ────────────────────────────────
# Au choix (voir docs/AI-STACK.md). Ex : fal.ai (Kling/Veo), Runway, Luma
RUNWAY_API_KEY=
LUMA_API_KEY=

# ── Connecteurs plateformes (Paid + Organic) ─────────────────
# Meta (Facebook/Instagram) — https://developers.facebook.com
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v21.0
# LinkedIn Ads — https://www.linkedin.com/developers
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# ── Réseaux additionnels (connecteurs déclaratifs, OAuth 2.0) ────────────────
# Ajouter un réseau = renseigner ces 2 clés + 1 objet de config dans
# lib/connectors/providers/. Aucune nouvelle route à écrire. Voir docs/CONNECTORS.md.
# Twitter/X — https://developer.twitter.com (Project → App → OAuth 2.0)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
# Pinterest — https://developers.pinterest.com (App → OAuth)
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
# Threads (Meta) — https://developers.facebook.com (produit « Threads API »)
THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=

# ── Analytics ────────────────────────────────────────────────
GA4_PROPERTY_ID=

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Secret partagé pour authentifier les webhooks de rendu (Replicate…).
# Mettre une valeur aléatoire en prod (URL publique requise pour les webhooks).
WEBHOOK_SECRET=

# ── MiroFish — moteur de simulation PREMIUM (self-hosted, Docker) ─────────────
# Laisser vide = moteur premium désactivé (seul le simulateur Claude standard est
# proposé). Renseigner l'URL de l'instance backend MiroFish pour l'activer.
# Voir docs/MIROFISH.md pour le déploiement.
MIROFISH_BASE_URL=
MIROFISH_API_KEY=
